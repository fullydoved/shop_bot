# Copy this to .env and fill in your values

# Django secret key (generate with: python -c "import secrets; print(secrets.token_urlsafe(50))")
DJANGO_SECRET_KEY=your-secret-key-here

# Claude API (get key from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model to use (claude-sonnet-4-6 is the latest Sonnet, claude-haiku-4-5-20251001 for cheapest)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Optional: Keep Ollama as fallback for casual chat
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# NFC: host:port written into NDEF URL records on tags
# NFC_HOST=192.168.1.85:42070
