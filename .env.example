# Copy this to .env and fill in your values

# Django secret key (generate with: python -c "import secrets; print(secrets.token_urlsafe(50))")
DJANGO_SECRET_KEY=your-secret-key-here

# Claude API (get key from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model to use (claude-sonnet-4-5-20250929 is the latest Sonnet 4.5)
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Optional: Keep Ollama as fallback for casual chat
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2
